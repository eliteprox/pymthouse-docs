{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "PymtHouse",
  "colors": {
    "primary": "#16A34A",
    "light": "#07C983",
    "dark": "#15803D"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Builder guides",
        "groups": [
          {
            "group": "Getting started",
            "pages": ["index", "quickstart"]
          },
          {
            "group": "Concepts",
            "pages": ["integration/client-model"]
          },
          {
            "group": "Authentication",
            "pages": [
              "integration/machine-access",
              "integration/interactive-login",
              "integration/device-flow",
              "integration/token-exchange"
            ]
          },
          {
            "group": "Builder API",
            "pages": [
              "integration/user-management",
              "integration/user-tokens"
            ]
          },
          {
            "group": "Usage API",
            "pages": ["integration/usage-api"]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Mintlify docs",
          "href": "https://mintlify.com/docs",
          "icon": "book-open-cover"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "contextual": {
    "options": ["copy", "view", "chatgpt", "claude", "cursor", "vscode"]
  }
}
